{
  "name": "call-ai-agent",
  "version": "0.1.0",
  "description": "Backend Node.js para agente IA de llamadas con Zadarma y DeepSeek",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "config:check:prod": "node scripts/config-check-prod.mjs",
    "check": "node --check src/server.js",
    "e2e:inbound": "bash scripts/e2e-inbound.sh",
    "db:migrate": "node src/db/run-migrations.js",
    "e2e:realtime": "node scripts/e2e-realtime.mjs",
    "e2e:realtime:strict": "node scripts/e2e-realtime.mjs --assert-no-fallback",
    "e2e:realtime:local": "bash scripts/e2e-realtime-local.sh",
    "e2e:hardening:local": "bash scripts/e2e-hardening-local.sh"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "mysql2": "^3.22.0",
    "pino": "^9.7.0",
    "ws": "^8.20.0",
    "zod": "^3.24.3"
  }
}
