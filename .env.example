NODE_ENV=development
PORT=3000
API_VERSION=v1
LOG_LEVEL=info

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_TIMEOUT_MS=12000

STORAGE_PROVIDER=memory
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=
MYSQL_CONNECTION_LIMIT=10
MYSQL_SSL_ENABLED=false
MYSQL_SSL_REJECT_UNAUTHORIZED=true

APPOINTMENTS_PROVIDER=memory
APPOINTMENTS_API_BASE_URL=http://localhost:4001
APPOINTMENTS_API_KEY=
APPOINTMENTS_API_AVAILABILITY_PATH=/api/v1/appointments/availability
APPOINTMENTS_API_CREATE_PATH=/api/v1/appointments
APPOINTMENTS_TIMEOUT_MS=6000
INTERNAL_API_KEY=
WEBHOOK_RATE_LIMIT_MAX=120
WEBHOOK_RATE_LIMIT_WINDOW_MS=60000
INTERNAL_RATE_LIMIT_MAX=60
INTERNAL_RATE_LIMIT_WINDOW_MS=60000

ZADARMA_SECRET=
ZADARMA_WEBHOOK_SIGNATURE_HEADER=x-zadarma-signature
ZADARMA_WEBHOOK_TIMESTAMP_HEADER=x-zadarma-timestamp
ZADARMA_WEBHOOK_TOLERANCE_SEC=300
ZADARMA_BASE_URL=https://api.zadarma.com
ZADARMA_API_KEY=
ZADARMA_API_SECRET=
ZADARMA_OUTBOUND_PATH=/v1/request/callback/

DEFAULT_TIMEZONE=Europe/Madrid
